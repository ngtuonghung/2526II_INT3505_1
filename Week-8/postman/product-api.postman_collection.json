{
  "info": {
    "_postman_id": "8f1e2c3f-7b08-41fd-8df8-3f7fc2f8f2cb",
    "name": "Week-8 Product API Test Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - GET /products - list products (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is JSON array', function () {",
              "  const contentType = pm.response.headers.get('Content-Type') || '';",
              "  pm.expect(contentType).to.include('application/json');",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/products"
      }
    },
    {
      "name": "02 - POST /products - create product (201)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('runSuffix', String(Date.now()));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Created product is valid', function () {",
              "  const contentType = pm.response.headers.get('Content-Type') || '';",
              "  pm.expect(contentType).to.include('application/json');",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('id');",
              "  pm.expect(data.id).to.match(/^[a-fA-F0-9]{24}$/);",
              "  pm.expect(data).to.have.property('name');",
              "  pm.expect(data).to.have.property('price');",
              "  pm.expect(data).to.have.property('stock');",
              "  pm.expect(data).to.have.property('description');",
              "  pm.expect(data).to.have.property('createdAt');",
              "  pm.collectionVariables.set('createdProductId', data.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{productNamePrefix}}-{{runSuffix}}\",\n  \"description\": \"created by Postman\",\n  \"price\": 19.99,\n  \"stock\": 15\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/products"
      }
    },
    {
      "name": "03 - GET /products/{id} - existing id (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Fetched product matches created id', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data.id).to.eql(pm.collectionVariables.get('createdProductId'));",
              "  pm.expect(data).to.have.property('name');",
              "  pm.expect(data).to.have.property('price');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/products/{{createdProductId}}"
      }
    },
    {
      "name": "04 - PUT /products/{id} - update existing (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Updated product fields are returned', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data.id).to.eql(pm.collectionVariables.get('createdProductId'));",
              "  pm.expect(data.name).to.include('updated');",
              "  pm.expect(data.price).to.eql(25.5);",
              "  pm.expect(data.stock).to.eql(9);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{productNamePrefix}}-updated-{{runSuffix}}\",\n  \"description\": \"updated by Postman\",\n  \"price\": 25.5,\n  \"stock\": 9\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/products/{{createdProductId}}"
      }
    },
